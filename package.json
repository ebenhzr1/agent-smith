{
  "name": "@agent-smith/cli",
  "version": "0.2.1",
  "description": "Agent Smith — The universal package manager for AI agent skills. Install, search, and publish skills for Claude, GPT, Gemini, and any AI agent.",
  "type": "module",
  "bin": {
    "agentsmith": "./bin/agentsmith.js"
  },
  "files": [
    "bin/",
    "src/",
    "built-in-skills/",
    "spec/"
  ],
  "scripts": {
    "agentsmith": "node bin/agentsmith.js",
    "test": "node --test test/*.test.js",
    "build": "echo 'No build step needed — pure ESM'",
    "prepare": "husky"
  },
  "keywords": [
    "ai-agent",
    "skills",
    "package-manager",
    "claude",
    "gpt",
    "agents",
    "registry",
    "agent-smith"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebenhzr1/agent-smith"
  },
  "bugs": {
    "url": "https://github.com/ebenhzr1/agent-smith/issues"
  },
  "homepage": "https://github.com/ebenhzr1/agent-smith#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "nanospinner": "^1.1.0",
    "semver": "^7.6.0"
  },
  "lint-staged": {
    "*.js": "node --check"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ebenhzr1"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  }
}
